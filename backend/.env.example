DATABASE_URL="postgresql://DB_USER:DB_PASSWORD@DB_HOST:5432/DB_NAME"
JWT_SECRET="replace-with-64-plus-random-characters"
JWT_EXPIRES_IN="7d"
FRONTEND_URL="http://localhost:5173"
ALLOWED_ORIGINS="http://localhost:5173"
PORT=5000
NODE_ENV=development
BCRYPT_ROUNDS=12
SEED_ADMIN_EMAIL="admin@shosa.ug"
SEED_ADMIN_PASSWORD="replace-with-strong-seed-password-min-16-chars"
SACCO_REG_FEE=50000
MAX_UPLOAD_SIZE=5242880

# SMTP transactional email settings for official receipt delivery
SMTP_HOST="smtp.provider.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your-smtp-login"
SMTP_PASS="your-smtp-key"
SMTP_FROM="SHOSA <receipts@example.com>"

# Optional public image locations for email receipts.
SEETA_LOGO_URL=""
SACCO_LOGO_URL=""