<template>
  <div class="space-y-6">
    <div class="flex flex-wrap items-end justify-between gap-4">
      <div><p class="font-bold text-gold">Admin alumni management</p><h1 class="text-3xl font-black text-navy dark:text-gold">Alumni Records</h1><p class="mt-2 text-slate-600 dark:text-slate-300">Search, filter and verify alumni without exposing password hashes.</p></div>
      <router-link class="btn-secondary" to="/admin">Back to dashboard</router-link>
    </div>
    <form class="card grid gap-3 md:grid-cols-5" @submit.prevent="load">
      <input v-model="filters.search" class="input md:col-span-2" placeholder="Search name, email, phone" />
      <select v-model="filters.campus" class="input"><option value="">All campuses</option><option value="main">Main</option><option value="mbalala">Mbalala</option><option value="green">Green</option><option value="alevel">A Level</option></select>
      <input v-model="filters.year" class="input" placeholder="Year e.g. 2024" />
      <select v-model="filters.status" class="input"><option value="">All statuses</option><option value="pending">Pending</option><option value="verified">Verified</option><option value="rejected">Rejected</option><option value="suspended">Suspended</option></select>
      <button class="btn-primary md:col-span-5">Apply Filters</button>
    </form>
    <section class="card overflow-x-auto">
      <table class="w-full text-sm">
        <thead><tr class="text-left"><th>Name</th><th>Email</th><th>Phone</th><th>Campus</th><th>Year</th><th>SACCO</th><th>Status</th><th>Action</th></tr></thead>
        <tbody>
          <tr v-for="a in alumni" :key="a.id" class="border-t border-slate-100 dark:border-slate-800">
            <td class="py-3 font-bold">{{ a.displayName }}</td><td>{{ a.email }}</td><td>{{ a.phone }}</td><td>{{ niceCampus(a.campus) }}</td><td>{{ a.gradYear }}</td><td>{{ a.saccoMembership?.status || '—' }}</td><td>{{ a.verificationStatus }}</td>
            <td><select class="input min-w-32" :value="a.verificationStatus" @change="updateStatus(a, $event.target.value)"><option value="pending">Pending</option><option value="verified">Verified</option><option value="rejected">Rejected</option><option value="suspended">Suspended</option></select></td>
          </tr>
          <tr v-if="!alumni.length"><td colspan="8" class="py-6 text-slate-500">No alumni records found.</td></tr>
        </tbody>
      </table>
    </section>
  </div>
</template>
<script setup>
import { onMounted, reactive, ref } from 'vue'; import api from '../api'
const alumni=ref([]); const filters=reactive({search:'',campus:'',year:'',status:''})
function niceCampus(v){ return String(v || '—').replace('alevel','A Level').replace(/\b\w/g, c => c.toUpperCase()) }
async function load(){ const params={}; Object.entries(filters).forEach(([k,v])=>{ if(v) params[k]=v }); alumni.value=(await api.get('/admin/alumni',{params})).data }
async function updateStatus(a,status){ await api.put(`/admin/alumni/${a.id}/verification`, { status }); await load() }
onMounted(load)
</script>
