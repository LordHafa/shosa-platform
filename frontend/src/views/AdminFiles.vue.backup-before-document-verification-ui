<template>
  <div class="space-y-6">
    <section class="overflow-hidden rounded-3xl bg-navy text-white shadow-xl">
      <div class="relative p-6 md:p-8">
        <div class="absolute inset-0 bg-gradient-to-br from-gold/10 via-transparent to-slate-950/50"></div>
        <div class="relative z-10 flex flex-wrap items-end justify-between gap-4">
          <div>
            <p class="font-bold text-gold">Private admin document vault</p>
            <h1 class="mt-2 text-3xl font-black md:text-5xl">Admin Files</h1>
            <p class="mt-3 max-w-3xl leading-7 text-slate-200">
              Upload, review, download and soft-delete private alumni documents. These files stay outside public website assets.
            </p>
          </div>
          <router-link class="btn-secondary" to="/admin">Back to dashboard</router-link>
        </div>
      </div>
    </section>

    <section class="card">
      <div class="grid gap-3 md:grid-cols-[1.5fr_1fr_auto_auto]">
        <input v-model="search" class="input" placeholder="Search alumni by name, email, phone" @keyup.enter="loadAlumni" />

        <select v-model="campus" class="input">
          <option value="">All campuses</option>
          <option v-for="option in campusOptions" :key="option.value" :value="option.value">{{ option.label }}</option>
        </select>

        <button class="btn-primary" @click="loadAlumni">Find Alumni</button>
        <button class="btn-secondary" @click="loadDocuments">Refresh Files</button>
      </div>
    </section>

    <section class="grid gap-6 xl:grid-cols-[1fr_1.05fr]">
      <div class="card">
        <div class="mb-4 flex flex-wrap items-center justify-between gap-3">
          <div>
            <h2 class="text-2xl font-black text-navy dark:text-gold">Select alumni</h2>
            <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">{{ alumni.length }} result(s)</p>
          </div>
          <button class="rounded-xl border border-slate-300 px-4 py-2 font-bold dark:border-slate-700" @click="clearSelection">
            Clear
          </button>
        </div>

        <div class="space-y-3 md:hidden">
          <article
            v-for="a in alumni"
            :key="a.id"
            class="rounded-2xl border p-4 transition"
            :class="selected?.id === a.id ? 'border-gold bg-gold/10' : 'border-slate-200 dark:border-slate-700'"
          >
            <div class="flex items-start justify-between gap-3">
              <div>
                <h3 class="font-black text-navy dark:text-white">{{ a.displayName }}</h3>
                <p class="mt-1 break-all text-sm text-slate-500">{{ a.email }}</p>
                <p class="mt-1 text-sm font-bold text-gold">{{ niceCampus(a.campus) }} • {{ a.gradYear || '-' }}</p>
              </div>
              <span :class="statusBadge(a.verificationStatus)">{{ niceStatus(a.verificationStatus) }}</span>
            </div>
            <button class="mt-4 w-full btn-secondary" @click="selectAlumni(a)">
              {{ selected?.id === a.id ? 'Selected' : 'Select alumni' }}
            </button>
          </article>

          <div v-if="!alumni.length" class="rounded-2xl bg-cream p-6 text-center text-slate-500 dark:bg-slate-800">
            No alumni loaded yet.
          </div>
        </div>

        <div class="hidden overflow-x-auto md:block">
          <table class="w-full min-w-[760px] text-left text-sm">
            <thead>
              <tr class="border-b border-slate-200 dark:border-slate-700">
                <th class="py-3">Name</th>
                <th>Email</th>
                <th>Campus</th>
                <th>Status</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <tr v-for="a in alumni" :key="a.id" class="border-b border-slate-100 dark:border-slate-800">
                <td class="py-3 font-bold">{{ a.displayName }}</td>
                <td>{{ a.email }}</td>
                <td>{{ niceCampus(a.campus) }}</td>
                <td><span :class="statusBadge(a.verificationStatus)">{{ niceStatus(a.verificationStatus) }}</span></td>
                <td>
                  <button class="btn-secondary" @click="selectAlumni(a)">
                    {{ selected?.id === a.id ? 'Selected' : 'Select' }}
                  </button>
                </td>
              </tr>
              <tr v-if="!alumni.length">
                <td colspan="5" class="py-6 text-slate-500">No alumni loaded yet.</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <div class="card">
        <div class="flex flex-wrap items-start justify-between gap-4">
          <div>
            <h2 class="text-2xl font-black text-navy dark:text-gold">Upload private document</h2>
            <p class="mt-1 text-sm text-slate-500">
              Selected: <strong>{{ selected?.displayName || 'None' }}</strong>
            </p>
          </div>
          <span v-if="selected" class="rounded-full bg-gold px-3 py-1 text-xs font-black text-navy">
            {{ niceCampus(selected.campus) }}
          </span>
        </div>

        <form class="mt-5 space-y-4" @submit.prevent="upload">
          <div>
            <label class="label">Document type</label>
            <select v-model="documentType" class="input" required>
              <option v-for="type in documentTypes" :key="type.value" :value="type.value">
                {{ type.label }}
              </option>
            </select>
          </div>

          <div
            class="rounded-3xl border-2 border-dashed border-gold/60 bg-gradient-to-br from-gold/10 via-cream to-white p-5 text-center transition dark:from-gold/10 dark:via-slate-900 dark:to-slate-950"
            :class="isDragging ? 'border-gold shadow-lg' : ''"
            @dragenter.prevent="isDragging = true"
            @dragover.prevent="isDragging = true"
            @dragleave.prevent="isDragging = false"
            @drop.prevent="handleDrop"
          >
            <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-2xl bg-navy text-sm font-black text-gold shadow">
              FILE
            </div>

            <h3 class="mt-4 text-xl font-black text-navy dark:text-gold">Drop a document here</h3>
            <p class="mx-auto mt-2 max-w-md text-sm leading-6 text-slate-500 dark:text-slate-400">
              PDF, JPG, PNG or WEBP. Use private files only: IDs, receipts, appointment letters, approvals or SACCO documents.
            </p>

            <button type="button" class="mt-4 btn-secondary" @click="openFilePicker">
              {{ file ? 'Change file' : 'Choose file' }}
            </button>

            <input
              ref="fileInput"
              type="file"
              accept="application/pdf,image/jpeg,image/png,image/webp"
              class="hidden"
              @change="onFileChange"
            />

            <div v-if="file" class="mt-4 rounded-2xl bg-white/80 p-4 text-left dark:bg-slate-800">
              <p class="truncate font-black text-navy dark:text-gold">{{ file.name }}</p>
              <p class="mt-1 text-sm text-slate-500">{{ file.type || 'Unknown type' }} • {{ fileSize(file.size) }}</p>
              <button type="button" class="mt-3 rounded-xl bg-red-600 px-4 py-2 font-bold text-white" @click="clearFile">
                Remove file
              </button>
            </div>
          </div>

          <p v-if="message" class="rounded-2xl bg-gold/20 p-4 font-semibold text-navy dark:text-gold">{{ message }}</p>
          <p v-if="error" class="rounded-2xl bg-red-100 p-4 font-semibold text-red-700">{{ error }}</p>

          <button class="btn-primary w-full" :disabled="uploading || !selected || !file">
            {{ uploading ? 'Uploading...' : 'Upload private document' }}
          </button>
        </form>
      </div>
    </section>

    <section class="card">
      <div class="mb-4 flex flex-wrap items-center justify-between gap-3">
        <div>
          <h2 class="text-2xl font-black text-navy dark:text-gold">Private Documents</h2>
          <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">
            {{ selected ? `Showing documents for ${selected.displayName}` : 'Showing latest private documents' }}
          </p>
        </div>
        <button class="btn-secondary" @click="loadDocuments">Refresh</button>
      </div>

      <div class="grid gap-3 md:grid-cols-2 xl:hidden">
        <article
          v-for="d in documents"
          :key="d.id"
          class="rounded-2xl border border-slate-200 bg-white p-4 dark:border-slate-700 dark:bg-slate-800"
        >
          <p class="text-xs font-bold uppercase tracking-wide text-gold">{{ niceType(d.documentType) }}</p>
          <h3 class="mt-1 truncate font-black text-navy dark:text-white">{{ d.originalFileName }}</h3>
          <p class="mt-1 text-sm text-slate-500">{{ d.alumni?.displayName || selected?.displayName || '-' }}</p>
          <div class="mt-3 grid grid-cols-2 gap-2 text-sm">
            <span class="rounded-xl bg-cream p-2 dark:bg-slate-900">{{ fileSize(d.sizeBytes) }}</span>
            <span class="rounded-xl bg-cream p-2 dark:bg-slate-900">{{ formatDate(d.createdAt) }}</span>
          </div>
          <div class="mt-4 grid grid-cols-2 gap-2">
            <button class="btn-secondary" @click="download(d)">Download</button>
            <button class="rounded-xl bg-red-600 px-4 py-3 font-bold text-white" @click="remove(d)">Delete</button>
          </div>
        </article>

        <div v-if="!documents.length" class="rounded-2xl bg-cream p-6 text-center text-slate-500 dark:bg-slate-800 md:col-span-2">
          No private documents yet.
        </div>
      </div>

      <div class="hidden overflow-x-auto xl:block">
        <table class="w-full min-w-[980px] text-sm">
          <thead>
            <tr class="text-left">
              <th>Alumni</th>
              <th>Type</th>
              <th>File</th>
              <th>Size</th>
              <th>Date</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            <tr v-for="d in documents" :key="d.id" class="border-t border-slate-100 dark:border-slate-800">
              <td class="py-3">{{ d.alumni?.displayName || selected?.displayName || '-' }}</td>
              <td>{{ niceType(d.documentType) }}</td>
              <td class="max-w-[320px] truncate font-bold">{{ d.originalFileName }}</td>
              <td>{{ fileSize(d.sizeBytes) }}</td>
              <td>{{ formatDate(d.createdAt) }}</td>
              <td class="space-x-2 whitespace-nowrap">
                <button class="btn-secondary" @click="download(d)">Download</button>
                <button class="rounded-xl bg-red-600 px-4 py-2 font-bold text-white" @click="remove(d)">Delete</button>
              </td>
            </tr>
            <tr v-if="!documents.length">
              <td colspan="6" class="py-6 text-slate-500">No private documents yet.</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>
  </div>
</template>

<script setup>
import { onMounted, ref } from 'vue'
import api, { API_URL } from '../api'

const campusOptions = [
  { label: 'Main Campus', value: 'Main Campus' },
  { label: 'Mbalala Campus', value: 'Mbalala Campus' },
  { label: 'Green Campus', value: 'Green Campus' },
  { label: 'A Level Campus', value: 'A Level Campus' }
]

const documentTypes = [
  { label: 'General document', value: 'general' },
  { label: 'National ID / Identification', value: 'identification' },
  { label: 'SACCO receipt / payment proof', value: 'sacco_receipt' },
  { label: 'Appointment / leadership letter', value: 'appointment_letter' },
  { label: 'Academic / alumni verification', value: 'alumni_verification' },
  { label: 'Consent / authorization', value: 'consent_authorization' },
  { label: 'Other private document', value: 'other' }
]

const alumni = ref([])
const documents = ref([])
const selected = ref(null)
const search = ref('')
const campus = ref('')
const documentType = ref('general')
const file = ref(null)
const fileInput = ref(null)
const message = ref('')
const error = ref('')
const uploading = ref(false)
const isDragging = ref(false)

function niceCampus(value) {
  return String(value || '-')
    .replace('alevel', 'A Level')
    .replace(/\b\w/g, c => c.toUpperCase())
}

function niceType(value) {
  return String(value || '-').replaceAll('_', ' ').replace(/\b\w/g, c => c.toUpperCase())
}

function niceStatus(value) {
  return niceType(value)
}

function statusBadge(status) {
  const base = 'inline-flex rounded-full px-3 py-1 text-xs font-black uppercase tracking-wide'
  if (status === 'verified') return `${base} bg-green-100 text-green-700`
  if (status === 'rejected') return `${base} bg-red-100 text-red-700`
  if (status === 'suspended') return `${base} bg-slate-200 text-slate-700`
  return `${base} bg-gold/25 text-navy dark:text-gold`
}

function fileSize(bytes) {
  const value = Number(bytes || 0)
  if (value >= 1024 * 1024) return `${(value / 1024 / 1024).toFixed(1)} MB`
  return `${Math.max(1, Math.round(value / 1024))} KB`
}

function formatDate(value) {
  if (!value) return '-'
  return new Date(value).toLocaleString()
}

function openFilePicker() {
  fileInput.value?.click()
}

function isAllowedFile(selectedFile) {
  const allowed = ['application/pdf', 'image/jpeg', 'image/png', 'image/webp']
  const extOk = /\.(pdf|jpe?g|png|webp)$/i.test(selectedFile?.name || '')
  return allowed.includes(selectedFile?.type) || extOk
}

function setFile(selectedFile) {
  error.value = ''
  message.value = ''

  if (!selectedFile) {
    clearFile()
    return
  }

  if (!isAllowedFile(selectedFile)) {
    clearFile()
    error.value = 'Only PDF, JPG, PNG or WEBP private documents are allowed.'
    return
  }

  file.value = selectedFile
}

function clearFile() {
  file.value = null
  if (fileInput.value) fileInput.value.value = ''
}

function onFileChange(event) {
  setFile(event.target.files?.[0] || null)
}

function handleDrop(event) {
  isDragging.value = false
  setFile(event.dataTransfer?.files?.[0] || null)
}

function clearSelection() {
  selected.value = null
  loadDocuments()
}

async function loadAlumni() {
  const params = {}
  if (search.value) params.search = search.value
  if (campus.value) params.campus = campus.value
  alumni.value = (await api.get('/admin/alumni', { params })).data
}

async function loadDocuments() {
  documents.value = (await api.get('/admin/documents')).data
}

async function selectAlumni(alumniRecord) {
  selected.value = alumniRecord
  documents.value = (await api.get(`/admin/users/${alumniRecord.id}/documents`)).data
}

async function upload() {
  if (!selected.value || !file.value) return

  uploading.value = true
  error.value = ''
  message.value = ''

  try {
    const fd = new FormData()
    fd.append('documentType', documentType.value)
    fd.append('document', file.value)

    await api.post(`/admin/users/${selected.value.id}/documents`, fd)
    message.value = 'Private document uploaded and audit logged.'
    clearFile()
    await selectAlumni(selected.value)
  } catch (e) {
    error.value = e.response?.data?.error || 'Private document upload failed'
  } finally {
    uploading.value = false
  }
}

function authHeaders() {
  const token = localStorage.getItem('token')
  return token ? { Authorization: `Bearer ${token}` } : {}
}

async function download(documentRecord) {
  const alumniId = documentRecord.alumniId || selected.value?.id
  if (!alumniId) {
    alert('Cannot download: alumni ID missing.')
    return
  }

  const response = await fetch(`${API_URL}/admin/users/${alumniId}/documents/${documentRecord.id}/download`, {
    headers: authHeaders()
  })

  if (!response.ok) {
    alert('Download failed')
    return
  }

  const blob = await response.blob()
  const url = URL.createObjectURL(blob)
  const anchor = document.createElement('a')
  anchor.href = url
  anchor.download = documentRecord.originalFileName
  anchor.click()
  URL.revokeObjectURL(url)
}

async function remove(documentRecord) {
  const alumniId = documentRecord.alumniId || selected.value?.id
  if (!alumniId) {
    alert('Cannot delete: alumni ID missing.')
    return
  }

  if (!confirm('Soft-delete this private document? This action will be audit logged.')) return

  await api.delete(`/admin/users/${alumniId}/documents/${documentRecord.id}`)
  message.value = 'Document soft-deleted and audit logged.'

  selected.value ? await selectAlumni(selected.value) : await loadDocuments()
}

onMounted(() => {
  loadAlumni()
  loadDocuments()
})
</script>
