<template>
  <div class="space-y-6">
    <div class="flex flex-wrap items-end justify-between gap-4"><div><p class="font-bold text-gold">Private admin document folder</p><h1 class="text-3xl font-black text-navy dark:text-gold">Admin Files</h1><p class="mt-2 text-slate-600 dark:text-slate-300">Upload private PDF/JPG/PNG/WEBP files against an alumni profile. These files are not public website assets.</p></div><router-link class="btn-secondary" to="/admin">Back to dashboard</router-link></div>
    <section class="card grid gap-3 md:grid-cols-5"><input v-model="search" class="input md:col-span-2" placeholder="Search alumni by name/email"><select v-model="campus" class="input"><option value="">All campuses</option><option value="main">Main</option><option value="mbalala">Mbalala</option><option value="green">Green</option><option value="alevel">A Level</option></select><button class="btn-primary" @click="loadAlumni">Find Alumni</button><button class="btn-secondary" @click="loadDocuments">Refresh Files</button></section>
    <section class="grid gap-6 lg:grid-cols-[1fr_1.2fr]">
      <div class="card overflow-x-auto"><h2 class="mb-4 text-xl font-black text-navy dark:text-gold">Select Alumni</h2><table class="w-full text-sm"><thead><tr class="text-left"><th>Name</th><th>Email</th><th>Campus</th><th></th></tr></thead><tbody><tr v-for="a in alumni" :key="a.id"><td class="py-2 font-bold">{{ a.displayName }}</td><td>{{ a.email }}</td><td>{{ a.campus }}</td><td><button class="btn-secondary" @click="selectAlumni(a)">Select</button></td></tr><tr v-if="!alumni.length"><td colspan="4" class="py-4 text-slate-500">No alumni loaded yet.</td></tr></tbody></table></div>
      <div class="card"><h2 class="text-xl font-black text-navy dark:text-gold">Upload Document</h2><p class="mt-1 text-sm text-slate-500">Selected: <strong>{{ selected?.displayName || 'None' }}</strong></p><form class="mt-4 grid gap-3" @submit.prevent="upload"><input v-model="documentType" class="input" placeholder="Document type e.g. appointment_letter, ID, receipt" required><input type="file" accept="application/pdf,image/jpeg,image/png,image/webp" @change="file=$event.target.files[0]" required><button class="btn-primary" :disabled="!selected">Upload private document</button></form></div>
    </section>
    <div v-if="message" class="rounded-2xl bg-gold/20 p-4 font-semibold text-navy dark:text-gold">{{ message }}</div>
    <section class="card overflow-x-auto"><h2 class="mb-4 text-xl font-black text-navy dark:text-gold">Private Documents</h2><table class="w-full text-sm"><thead><tr class="text-left"><th>Alumni</th><th>Type</th><th>File</th><th>Size</th><th>Date</th><th>Action</th></tr></thead><tbody><tr v-for="d in documents" :key="d.id"><td class="py-2">{{ d.alumni?.displayName || selected?.displayName || '—' }}</td><td>{{ d.documentType }}</td><td>{{ d.originalFileName }}</td><td>{{ Math.round(d.sizeBytes/1024) }} KB</td><td>{{ new Date(d.createdAt).toLocaleString() }}</td><td class="space-x-2 whitespace-nowrap"><button class="btn-secondary" @click="download(d)">Download</button><button class="rounded-xl bg-red-600 px-4 py-2 text-white" @click="remove(d)">Delete</button></td></tr><tr v-if="!documents.length"><td colspan="6" class="py-4 text-slate-500">No private documents yet.</td></tr></tbody></table></section>
  </div>
</template>
<script setup>
import { onMounted, ref } from 'vue'; import api, { API_URL } from '../api'
const alumni=ref([]); const documents=ref([]); const selected=ref(null); const search=ref(''); const campus=ref(''); const documentType=ref('general'); const file=ref(null); const message=ref('')
async function loadAlumni(){ const params={}; if(search.value) params.search=search.value; if(campus.value) params.campus=campus.value; alumni.value=(await api.get('/admin/alumni',{params})).data }
async function loadDocuments(){ documents.value=(await api.get('/admin/documents')).data }
async function selectAlumni(a){ selected.value=a; documents.value=(await api.get(`/admin/users/${a.id}/documents`)).data }
async function upload(){ if(!selected.value || !file.value) return; const fd=new FormData(); fd.append('documentType',documentType.value); fd.append('document',file.value); await api.post(`/admin/users/${selected.value.id}/documents`, fd); message.value='Private document uploaded and audit logged.'; file.value=null; await selectAlumni(selected.value) }
function authHeaders(){ const token=localStorage.getItem('token'); return token ? { Authorization:`Bearer ${token}` } : {} }
async function download(d){ const res=await fetch(`${API_URL}/admin/users/${d.alumniId}/documents/${d.id}/download`, { headers: authHeaders() }); if(!res.ok){ alert('Download failed'); return } const blob=await res.blob(); const url=URL.createObjectURL(blob); const a=document.createElement('a'); a.href=url; a.download=d.originalFileName; a.click(); URL.revokeObjectURL(url) }
async function remove(d){ if(!confirm('Soft-delete this private document?')) return; await api.delete(`/admin/users/${d.alumniId}/documents/${d.id}`); message.value='Document soft-deleted and audit logged.'; selected.value ? await selectAlumni(selected.value) : await loadDocuments() }
onMounted(()=>{ loadAlumni(); loadDocuments() })
</script>
