<template>
  <section class="mx-auto max-w-5xl space-y-6">
    <div class="rounded-3xl bg-navy p-6 text-white shadow-xl md:p-8">
      <p class="font-bold text-gold">Join the SACCO</p>
      <h1 class="mt-2 text-3xl font-black md:text-4xl">Start your Seeta Alumni SACCO membership</h1>
      <p class="mt-3 max-w-3xl leading-7 text-slate-200">
        SACCO registration starts with the fixed UGX 50,000 registration fee. Yearly subscription becomes due 6 months after activation.
      </p>
    </div>

    <div class="grid gap-5 md:grid-cols-3">
      <div class="card">
        <p class="font-bold text-gold">1</p>
        <h3 class="text-xl font-black">Submit request</h3>
        <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">Confirm membership type, contribution plan, and consent.</p>
      </div>

      <div class="card">
        <p class="font-bold text-gold">2</p>
        <h3 class="text-xl font-black">Pay registration fee</h3>
        <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">The first SACCO payment is fixed at UGX 50,000.</p>
      </div>

      <div class="card">
        <p class="font-bold text-gold">3</p>
        <h3 class="text-xl font-black">Admin verification</h3>
        <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">Admin approval activates SACCO membership and audit logs the action.</p>
      </div>
    </div>

    <form class="card grid gap-4 md:grid-cols-2" @submit.prevent="submit">
      <div>
        <label class="label">Membership Type</label>
        <select v-model="form.membershipType" class="input">
          <option value="ordinary">Ordinary Member</option>
          <option value="founding">Founding / Support Member</option>
        </select>
      </div>

      <div>
        <label class="label">Planned Monthly Contribution UGX</label>
        <select v-model="form.monthlyContribution" class="input">
          <option value="">Select planned contribution</option>
          <option v-for="amount in monthlyOptions" :key="amount" :value="String(amount)">
            {{ money(amount) }}
          </option>
        </select>
      </div>

      <div>
        <label class="label">Preferred Start Date</label>
        <input v-model="form.startDate" class="input" type="date" />
      </div>

      <div>
        <label class="label">Registration Fee</label>
        <input class="input bg-slate-100 font-black dark:bg-slate-800" value="UGX 50,000" disabled />
      </div>

      <div>
        <label class="label">Payment Phone</label>
        <input v-model.trim="form.phone" class="input" placeholder="+256 778120798" />
      </div>

      <div>
        <label class="label">Payment Network</label>
        <select v-model="form.network" class="input">
          <option>MTN Mobile Money</option>
          <option>Airtel Money</option>
          <option>Bank Transfer</option>
          <option>Cash / Manual Deposit</option>
          <option>Other</option>
        </select>
      </div>

      <div class="md:col-span-2">
        <label class="label">Transaction Reference</label>
        <input v-model.trim="form.transactionRef" class="input" placeholder="Enter reference if payment has already been made" />
      </div>

      <label class="md:col-span-2 flex items-start gap-3 rounded-2xl bg-cream p-4 text-sm dark:bg-slate-800">
        <input v-model="form.consent" type="checkbox" required class="mt-1" />
        <span>
          I understand that SACCO membership only becomes active after authorized admin verification of the UGX 50,000 registration payment.
        </span>
      </label>

      <p v-if="message" class="md:col-span-2 rounded-lg bg-green-100 p-3 text-green-700">{{ message }}</p>
      <p v-if="error" class="md:col-span-2 rounded-lg bg-red-100 p-3 text-red-700">{{ error }}</p>

      <button class="btn-primary md:col-span-2" :disabled="loading">
        {{ loading ? 'Submitting...' : 'Submit SACCO Registration' }}
      </button>
    </form>
  </section>
</template>

<script setup>
import { reactive, ref } from 'vue'
import { useRouter } from 'vue-router'
import api from '../api'

const router = useRouter()
const loading = ref(false)
const error = ref('')
const message = ref('')

const monthlyOptions = [50000, 100000, 200000, 500000]

const form = reactive({
  membershipType: 'ordinary',
  monthlyContribution: '',
  startDate: '',
  phone: '',
  network: 'MTN Mobile Money',
  transactionRef: '',
  consent: false
})

function money(value) {
  return 'UGX ' + Number(value || 0).toLocaleString('en-UG')
}

async function submit() {
  loading.value = true
  error.value = ''
  message.value = ''

  try {
    await api.post('/sacco/register', form)
    message.value = 'SACCO request submitted. Redirecting to SACCO dashboard...'
    setTimeout(() => router.push('/sacco/dashboard'), 900)
  } catch (e) {
    error.value = e.response?.data?.error || 'SACCO registration failed'
  } finally {
    loading.value = false
  }
}
</script>
