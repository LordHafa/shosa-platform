<template>
  <section class="mx-auto max-w-6xl space-y-6">
    <div class="rounded-3xl bg-navy p-6 text-white shadow-xl md:p-8">
      <p class="font-bold text-gold">SACCO payments</p>
      <h1 class="mt-2 text-3xl font-black md:text-4xl">Submit and track payments</h1>
      <p class="mt-3 max-w-3xl leading-7 text-slate-200">
        Record mobile money or manual payment details for admin verification. Your payment remains pending until an admin confirms it.
      </p>
    </div>

    <div class="grid gap-6 lg:grid-cols-[420px_1fr]">
      <form class="card space-y-4" @submit.prevent="submitPayment">
        <div>
          <h2 class="text-2xl font-black text-navy dark:text-gold">New payment record</h2>
          <p class="mt-2 text-sm leading-6 text-slate-500 dark:text-slate-400">
            Use the transaction reference from Mobile Money or your bank slip where possible.
          </p>
        </div>

        <div>
          <label class="label">Payment Type *</label>
          <select v-model="form.paymentType" class="input" required>
            <option value="sacco_yearly_subscription">Yearly SACCO Subscription</option>
            <option value="sacco_savings_monthly">Monthly Savings</option>
            <option value="sacco_savings_quarterly">Quarterly Savings</option>
            <option value="donation">Donation</option>
            <option value="merchandise_order">Merchandise Order</option>
            <option value="event_fee">Event Fee</option>
            <option value="other">Other</option>
          </select>
        </div>

        <div>
          <label class="label">Amount UGX *</label>
          <input v-model="form.amount" class="input" inputmode="numeric" placeholder="50000" required />
        </div>

        <div>
          <label class="label">Phone Number *</label>
          <input v-model.trim="form.phone" class="input" inputmode="tel" required placeholder="0772000000" />
        </div>

        <div>
          <label class="label">Network *</label>
          <select v-model="form.network" class="input" required>
            <option>MTN Mobile Money</option>
            <option>Airtel Money</option>
            <option>Bank Transfer</option>
            <option>Cash / Manual Deposit</option>
            <option>Other</option>
          </select>
        </div>

        <div>
          <label class="label">Transaction Reference</label>
          <input v-model.trim="form.transactionRef" class="input" placeholder="Optional but recommended" />
          <p class="mt-1 text-xs text-slate-500 dark:text-slate-400">
            Helps admins verify faster and prevents duplicate payment confusion.
          </p>
        </div>

        <div>
          <label class="label">Description</label>
          <textarea v-model.trim="form.description" class="input min-h-24"></textarea>
        </div>

        <p v-if="message" class="rounded-lg bg-green-100 p-3 text-green-700">{{ message }}</p>
        <p v-if="error" class="rounded-lg bg-red-100 p-3 text-red-700">{{ error }}</p>

        <button class="btn-primary w-full" :disabled="loading">
          {{ loading ? 'Submitting...' : 'Submit Payment for Review' }}
        </button>
      </form>

      <div class="card">
        <div class="mb-4 flex flex-wrap items-center justify-between gap-3">
          <div>
            <h2 class="text-2xl font-black text-navy dark:text-gold">My payment history</h2>
            <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">Track approval status and references.</p>
          </div>
          <button class="btn-secondary" @click="loadPayments">Refresh</button>
        </div>

        <!-- Mobile payment cards -->
        <div class="space-y-3 md:hidden">
          <article
            v-for="p in payments"
            :key="p.id"
            class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-800"
          >
            <div class="flex items-start justify-between gap-3">
              <div>
                <p class="text-xs font-bold uppercase tracking-wide text-gold">{{ p.label || niceType(p.paymentType) }}</p>
                <h3 class="mt-1 text-xl font-black text-navy dark:text-white">{{ money(p.amount) }}</h3>
              </div>
              <span :class="statusBadge(p.status)">{{ niceStatus(p.status) }}</span>
            </div>

            <div class="mt-4 grid gap-2 text-sm text-slate-600 dark:text-slate-300">
              <div class="flex justify-between gap-3">
                <span class="text-slate-400">Date</span>
                <strong>{{ formatDate(p.createdAt) }}</strong>
              </div>
              <div class="flex justify-between gap-3">
                <span class="text-slate-400">Network</span>
                <strong class="text-right">{{ p.network || '-' }}</strong>
              </div>
              <div class="flex justify-between gap-3">
                <span class="text-slate-400">Reference</span>
                <strong class="max-w-[160px] truncate text-right">{{ p.transactionRef || '-' }}</strong>
              </div>
            </div>
          </article>

          <div v-if="!payments.length" class="rounded-2xl bg-cream p-6 text-center text-slate-500 dark:bg-slate-800">
            No payments yet.
          </div>
        </div>

        <!-- Desktop table -->
        <div class="hidden overflow-x-auto md:block">
          <table class="w-full min-w-[760px] text-left text-sm">
            <thead>
              <tr class="border-b border-slate-200 dark:border-slate-700">
                <th class="py-3">Date</th>
                <th>Type</th>
                <th>Amount</th>
                <th>Network</th>
                <th>Status</th>
                <th>Reference</th>
              </tr>
            </thead>
            <tbody>
              <tr v-for="p in payments" :key="p.id" class="border-b border-slate-100 dark:border-slate-700">
                <td class="py-3">{{ formatDate(p.createdAt) }}</td>
                <td>{{ p.label || niceType(p.paymentType) }}</td>
                <td>{{ money(p.amount) }}</td>
                <td>{{ p.network || '-' }}</td>
                <td><span :class="statusBadge(p.status)">{{ niceStatus(p.status) }}</span></td>
                <td>{{ p.transactionRef || '-' }}</td>
              </tr>
              <tr v-if="!payments.length">
                <td colspan="6" class="py-8 text-center text-slate-500">No payments yet.</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>
</template>

<script setup>
import { onMounted, reactive, ref } from 'vue'
import api from '../api'

const payments = ref([])
const loading = ref(false)
const error = ref('')
const message = ref('')

const form = reactive({
  paymentType: 'sacco_yearly_subscription',
  amount: '',
  phone: '',
  network: 'MTN Mobile Money',
  transactionRef: '',
  description: ''
})

function money(value) {
  return 'UGX ' + Number(value || 0).toLocaleString('en-UG')
}

function formatDate(value) {
  if (!value) return '-'
  return new Date(value).toLocaleDateString()
}

function niceType(value) {
  return String(value || '-').replaceAll('_', ' ').replace(/\b\w/g, c => c.toUpperCase())
}

function niceStatus(value) {
  return niceType(value)
}

function statusBadge(status) {
  const base = 'inline-flex rounded-full px-3 py-1 text-xs font-black uppercase tracking-wide'

  if (status === 'approved') return `${base} bg-green-100 text-green-700`
  if (status === 'rejected') return `${base} bg-red-100 text-red-700`
  if (status === 'pending_gateway_confirmation') return `${base} bg-blue-100 text-blue-700`

  return `${base} bg-gold/25 text-navy dark:text-gold`
}

async function loadPayments() {
  payments.value = (await api.get('/payments/my')).data
}

async function submitPayment() {
  loading.value = true
  error.value = ''
  message.value = ''

  try {
    await api.post('/payments/mobilemoney', form)
    message.value = 'Payment submitted for admin review.'
    Object.assign(form, {
      paymentType: 'sacco_yearly_subscription',
      amount: '',
      phone: '',
      network: 'MTN Mobile Money',
      transactionRef: '',
      description: ''
    })
    await loadPayments()
  } catch (e) {
    error.value = e.response?.data?.error || 'Payment submission failed'
  } finally {
    loading.value = false
  }
}

onMounted(loadPayments)
</script>
