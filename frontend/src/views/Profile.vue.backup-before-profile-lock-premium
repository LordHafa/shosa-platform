<template>
  <section class="mx-auto max-w-6xl space-y-6">
    <div class="rounded-3xl bg-navy p-6 text-white shadow-xl md:p-8">
      <p class="font-bold text-gold">My alumni profile</p>
      <h1 class="mt-2 text-3xl font-black md:text-4xl">Keep your Seeta record current</h1>
      <p class="mt-3 max-w-3xl leading-7 text-slate-200">
        Update safe profile fields, add a profile photo, and keep your alumni/SACCO records easy for administrators to verify.
      </p>
    </div>

    <div class="grid gap-6 lg:grid-cols-[1fr_2fr]">
      <aside class="card">
        <div class="flex items-center gap-4">
          <img :src="previewPhotoUrl" alt="Profile photo" class="h-24 w-24 rounded-3xl object-cover ring-4 ring-gold/30" />
          <div>
            <h2 class="text-2xl font-black text-navy dark:text-gold">{{ profile?.displayName || 'Alumni Member' }}</h2>
            <p class="text-sm text-slate-500">{{ profile?.campus }} • {{ profile?.gradYear }}</p>
            <p class="mt-2 inline-flex rounded-full bg-cream px-3 py-1 text-sm font-bold text-navy dark:bg-slate-800 dark:text-gold">
              {{ profile?.verificationStatus || 'pending' }}
            </p>
          </div>
        </div>

        <form class="mt-6 space-y-4" @submit.prevent="uploadPhoto">
          <label class="label">Profile photo</label>

          <div
            class="rounded-3xl border-2 border-dashed border-gold/60 bg-gradient-to-br from-gold/10 via-cream to-white p-4 text-center transition dark:from-gold/10 dark:via-slate-900 dark:to-slate-950"
            :class="isDragging ? 'border-gold shadow-lg' : ''"
            @dragenter.prevent="isDragging = true"
            @dragover.prevent="isDragging = true"
            @dragleave.prevent="isDragging = false"
            @drop.prevent="handlePhotoDrop"
          >
            <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-navy text-sm font-black text-gold shadow">
              PIC
            </div>

            <h3 class="mt-3 font-black text-navy dark:text-gold">Choose a clean profile photo</h3>
            <p class="mt-1 text-xs leading-5 text-slate-500 dark:text-slate-400">
              JPG, PNG or WEBP. Use a clear image that admins can recognise.
            </p>

            <button type="button" class="mt-4 btn-secondary w-full" @click="openPhotoPicker">
              {{ photoFile ? 'Change selected photo' : 'Choose photo' }}
            </button>

            <input
              ref="photoInput"
              type="file"
              accept="image/png,image/jpeg,image/webp"
              class="hidden"
              @change="onPhotoChange"
            />

            <p v-if="photoFile" class="mt-3 truncate rounded-xl bg-white/80 px-3 py-2 text-xs font-bold text-navy dark:bg-slate-800 dark:text-gold">
              Selected: {{ photoFile.name }}
            </p>
          </div>

          <button class="btn-secondary w-full" :disabled="photoLoading || !photoFile">
            {{ photoLoading ? 'Uploading...' : 'Upload Photo' }}
          </button>
        </form>
      </aside>

      <form class="card grid gap-4 md:grid-cols-2" @submit.prevent="saveProfile">
        <div>
          <label class="label">Phone</label>
          <input v-model.trim="form.phone" class="input" inputmode="tel" />
        </div>

        <div>
          <label class="label">Occupation</label>
          <input v-model.trim="form.occupation" class="input" />
        </div>

        <div>
          <label class="label">City</label>
          <input v-model.trim="form.city" class="input" />
        </div>

        <div>
          <label class="label">Country</label>
          <input v-model.trim="form.country" class="input" />
        </div>

        <div>
          <label class="label">House</label>
          <input v-model.trim="form.house" class="input" />
        </div>

        <div>
          <label class="label">Level / Section Attended</label>
          <select v-model="form.attendanceLevel" class="input">
            <option value="">Select level attended</option>
            <option v-for="option in attendanceOptions" :key="option" :value="option">{{ option }}</option>
          </select>
        </div>

        <div v-if="isPartialAttendance" class="md:col-span-2">
          <label class="label">Brief Attendance Note</label>
          <input
            v-model.trim="form.attendanceNote"
            class="input"
            placeholder="e.g. Joined in S.2, left after S.3"
          />
        </div>

        <div class="md:col-span-2">
          <label class="label">Bio</label>
          <textarea v-model.trim="form.bio" class="input min-h-32" placeholder="Share a short professional/community profile"></textarea>
        </div>

        <p v-if="message" class="md:col-span-2 rounded-lg bg-green-100 p-3 text-green-700">{{ message }}</p>
        <p v-if="error" class="md:col-span-2 rounded-lg bg-red-100 p-3 text-red-700">{{ error }}</p>

        <button class="btn-primary md:col-span-2" :disabled="loading">
          {{ loading ? 'Saving...' : 'Save Profile' }}
        </button>
      </form>
    </div>
  </section>
</template>

<script setup>
import { computed, onBeforeUnmount, onMounted, reactive, ref } from 'vue'
import api, { UPLOADS_URL } from '../api'

const profile = ref(null)
const loading = ref(false)
const photoLoading = ref(false)
const error = ref('')
const message = ref('')
const photoFile = ref(null)
const photoPreview = ref('')
const photoInput = ref(null)
const isDragging = ref(false)

const attendanceOptions = [
  'S.1 - S.4 / O-Level',
  'S.5 - S.6 / A-Level',
  'S.1 - S.6 / O-Level and A-Level',
  'Partial / Non-continuous attendance'
]

const form = reactive({
  phone: '',
  occupation: '',
  city: '',
  country: 'Uganda',
  house: '',
  attendanceLevel: '',
  attendanceNote: '',
  bio: ''
})

const photoUrl = computed(() => {
  return profile.value?.profilePhoto ? `${UPLOADS_URL}${profile.value.profilePhoto}` : '/assets/reference/seeta-reference-logo.jpeg'
})

const previewPhotoUrl = computed(() => photoPreview.value || photoUrl.value)

const isPartialAttendance = computed(() => form.attendanceLevel === 'Partial / Non-continuous attendance')

function parsePeriod(value) {
  const text = String(value || '').trim()

  if (!text) return { attendanceLevel: '', attendanceNote: '' }

  if (attendanceOptions.includes(text)) {
    return { attendanceLevel: text, attendanceNote: '' }
  }

  if (text.startsWith('Partial / Non-continuous attendance')) {
    return {
      attendanceLevel: 'Partial / Non-continuous attendance',
      attendanceNote: text.split(':').slice(1).join(':').trim()
    }
  }

  const yearRange = text.match(/(\d{4})\D+(\d{4})/)
  if (yearRange) {
    const start = Number(yearRange[1])
    const end = Number(yearRange[2])
    const difference = end - start

    if (difference >= 5) return { attendanceLevel: 'S.1 - S.6 / O-Level and A-Level', attendanceNote: '' }
    if (difference >= 3) return { attendanceLevel: 'S.1 - S.4 / O-Level', attendanceNote: '' }

    return {
      attendanceLevel: 'Partial / Non-continuous attendance',
      attendanceNote: `Previously recorded: ${text}`
    }
  }

  return {
    attendanceLevel: 'Partial / Non-continuous attendance',
    attendanceNote: text
  }
}

function buildPeriod() {
  if (!form.attendanceLevel) return ''

  if (isPartialAttendance.value && form.attendanceNote.trim()) {
    return `${form.attendanceLevel}: ${form.attendanceNote.trim()}`
  }

  return form.attendanceLevel
}

function fillForm(data) {
  const parsedPeriod = parsePeriod(data.period)

  Object.assign(form, {
    phone: data.phone || '',
    occupation: data.occupation || '',
    city: data.city || '',
    country: data.country || 'Uganda',
    house: data.house || '',
    attendanceLevel: parsedPeriod.attendanceLevel,
    attendanceNote: parsedPeriod.attendanceNote,
    bio: data.bio || ''
  })
}

async function loadProfile() {
  const { data } = await api.get('/me')
  profile.value = data
  fillForm(data)
}

function openPhotoPicker() {
  photoInput.value?.click()
}

function isAllowedImage(file) {
  const typeOk = ['image/jpeg', 'image/png', 'image/webp'].includes(file.type)
  const extOk = /\.(jpe?g|png|webp)$/i.test(file.name)
  return typeOk || extOk
}

function setPhotoFile(file) {
  error.value = ''
  message.value = ''

  if (!file) {
    clearPhotoSelection()
    return
  }

  if (!isAllowedImage(file)) {
    clearPhotoSelection()
    error.value = 'Please choose a JPG, PNG or WEBP image.'
    return
  }

  clearPhotoPreview()
  photoFile.value = file
  photoPreview.value = URL.createObjectURL(file)
}

function onPhotoChange(event) {
  setPhotoFile(event.target.files?.[0] || null)
  event.target.value = ''
}

function handlePhotoDrop(event) {
  isDragging.value = false
  setPhotoFile(event.dataTransfer?.files?.[0] || null)
}

function clearPhotoPreview() {
  if (photoPreview.value) {
    URL.revokeObjectURL(photoPreview.value)
    photoPreview.value = ''
  }
}

function clearPhotoSelection() {
  photoFile.value = null
  clearPhotoPreview()
}

async function uploadPhoto() {
  if (!photoFile.value) return

  photoLoading.value = true
  error.value = ''
  message.value = ''

  try {
    const fd = new FormData()
    fd.append('photo', photoFile.value)

    await api.post('/profile/photo', fd, { headers: { 'Content-Type': 'multipart/form-data' } })
    clearPhotoSelection()
    await loadProfile()
    message.value = 'Profile photo updated.'
  } catch (e) {
    error.value = e.response?.data?.error || 'Photo upload failed'
  } finally {
    photoLoading.value = false
  }
}

async function saveProfile() {
  loading.value = true
  error.value = ''
  message.value = ''

  try {
    const payload = {
      phone: form.phone,
      occupation: form.occupation,
      city: form.city,
      country: form.country,
      house: form.house,
      period: buildPeriod(),
      bio: form.bio
    }

    const { data } = await api.put('/me', payload)
    profile.value = data
    fillForm(data)
    message.value = 'Profile updated successfully.'
  } catch (e) {
    error.value = e.response?.data?.error || 'Profile update failed'
  } finally {
    loading.value = false
  }
}

onMounted(loadProfile)

onBeforeUnmount(() => {
  clearPhotoPreview()
})
</script>
