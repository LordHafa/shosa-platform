<template>
  <section class="mx-auto max-w-6xl space-y-6">
    <div class="rounded-3xl bg-navy p-8 text-white shadow-xl">
      <p class="font-bold text-gold">My alumni profile</p>
      <h1 class="mt-2 text-3xl font-black md:text-4xl">Keep your Seeta record current</h1>
      <p class="mt-3 max-w-3xl leading-7 text-slate-200">
        Update safe profile fields, add a profile photo, and keep your alumni/SACCO records easy for administrators to verify.
      </p>
    </div>

    <div class="grid gap-6 lg:grid-cols-[1fr_2fr]">
      <aside class="card">
        <div class="flex items-center gap-4">
          <img :src="photoUrl" alt="Profile photo" class="h-24 w-24 rounded-3xl object-cover ring-4 ring-gold/30" />
          <div>
            <h2 class="text-2xl font-black text-navy dark:text-gold">{{ profile?.displayName || 'Alumni Member' }}</h2>
            <p class="text-sm text-slate-500">{{ profile?.campus }} • {{ profile?.gradYear }}</p>
            <p class="mt-2 inline-flex rounded-full bg-cream px-3 py-1 text-sm font-bold text-navy dark:bg-slate-800 dark:text-gold">{{ profile?.verificationStatus || 'pending' }}</p>
          </div>
        </div>
        <form class="mt-6 space-y-3" @submit.prevent="uploadPhoto">
          <label class="label">Upload profile photo</label>
          <input type="file" accept="image/png,image/jpeg,image/webp" class="input" @change="onPhotoChange" />
          <button class="btn-secondary w-full" :disabled="photoLoading || !photoFile">{{ photoLoading ? 'Uploading...' : 'Upload Photo' }}</button>
        </form>
      </aside>

      <form class="card grid gap-4 md:grid-cols-2" @submit.prevent="saveProfile">
        <div><label class="label">Phone</label><input v-model.trim="form.phone" class="input" /></div>
        <div><label class="label">Occupation</label><input v-model.trim="form.occupation" class="input" /></div>
        <div><label class="label">City</label><input v-model.trim="form.city" class="input" /></div>
        <div><label class="label">Country</label><input v-model.trim="form.country" class="input" /></div>
        <div><label class="label">House</label><input v-model.trim="form.house" class="input" /></div>
        <div><label class="label">Period Attended</label><input v-model.trim="form.period" class="input" /></div>
        <div class="md:col-span-2"><label class="label">Bio</label><textarea v-model.trim="form.bio" class="input min-h-32" placeholder="Share a short professional/community profile"></textarea></div>
        <p v-if="message" class="md:col-span-2 rounded-lg bg-green-100 p-3 text-green-700">{{ message }}</p>
        <p v-if="error" class="md:col-span-2 rounded-lg bg-red-100 p-3 text-red-700">{{ error }}</p>
        <button class="btn-primary md:col-span-2" :disabled="loading">{{ loading ? 'Saving...' : 'Save Profile' }}</button>
      </form>
    </div>
  </section>
</template>

<script setup>
import { computed, onMounted, reactive, ref } from 'vue'
import api, { UPLOADS_URL } from '../api'

const profile = ref(null)
const loading = ref(false)
const photoLoading = ref(false)
const error = ref('')
const message = ref('')
const photoFile = ref(null)
const form = reactive({ phone: '', occupation: '', city: '', country: 'Uganda', house: '', period: '', bio: '' })

const photoUrl = computed(() => profile.value?.profilePhoto ? `${UPLOADS_URL}${profile.value.profilePhoto}` : '/assets/reference/seeta-reference-logo.jpeg')

function fillForm(data) {
  Object.assign(form, {
    phone: data.phone || '', occupation: data.occupation || '', city: data.city || '', country: data.country || 'Uganda',
    house: data.house || '', period: data.period || '', bio: data.bio || ''
  })
}
async function loadProfile() {
  const { data } = await api.get('/me')
  profile.value = data
  fillForm(data)
}
function onPhotoChange(event) { photoFile.value = event.target.files?.[0] || null }
async function uploadPhoto() {
  if (!photoFile.value) return
  photoLoading.value = true; error.value = ''; message.value = ''
  try {
    const fd = new FormData(); fd.append('photo', photoFile.value)
    await api.post('/profile/photo', fd, { headers: { 'Content-Type': 'multipart/form-data' } })
    await loadProfile(); message.value = 'Profile photo updated.'
  } catch (e) { error.value = e.response?.data?.error || 'Photo upload failed' }
  finally { photoLoading.value = false }
}
async function saveProfile() {
  loading.value = true; error.value = ''; message.value = ''
  try {
    const { data } = await api.put('/me', form)
    profile.value = data; message.value = 'Profile updated successfully.'
  } catch (e) { error.value = e.response?.data?.error || 'Profile update failed' }
  finally { loading.value = false }
}
onMounted(loadProfile)
</script>
