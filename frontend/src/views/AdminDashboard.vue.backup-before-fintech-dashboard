<template>
  <div class="space-y-6">
    <div class="flex flex-wrap items-start justify-between gap-4">
      <div>
        <p class="font-bold text-gold">Seeta Admin Command Center</p>
        <h1 class="text-3xl font-black text-navy dark:text-gold">Admin Dashboard</h1>
        <p class="mt-2 max-w-3xl text-slate-600 dark:text-slate-300">Track alumni records, SACCO verification, payment approvals, contact messages, private files, gallery uploads and audit-first platform activity.</p>
      </div>
      <div class="flex flex-wrap gap-3">
        <router-link class="btn-secondary" to="/admin/alumni">Alumni</router-link>
        <router-link class="btn-secondary" to="/admin/payments">Payments</router-link>
        <router-link class="btn-secondary" to="/admin/gallery">Gallery</router-link>
        <router-link class="btn-secondary" to="/admin/files">Files</router-link>
        <router-link class="btn-secondary" to="/admin/contacts">Contacts</router-link>
        <router-link class="btn-secondary" to="/admin/audit-logs">Audit Logs</router-link>
        <router-link class="btn-secondary" to="/admin/users">Admin Users</router-link>
      </div>
    </div>

    <div class="grid gap-5 md:grid-cols-3 xl:grid-cols-6">
      <div v-for="card in kpiCards" :key="card.label" class="card">
        <p class="text-sm text-slate-500">{{ card.label }}</p>
        <p class="mt-1 text-2xl font-black text-navy dark:text-gold">{{ card.value }}</p>
        <p class="mt-2 text-xs text-slate-500">{{ card.hint }}</p>
      </div>
    </div>

    <div class="grid gap-6 lg:grid-cols-2">
      <section class="card">
        <div class="mb-5 flex items-center justify-between"><h2 class="text-xl font-black text-navy dark:text-gold">Collections Trend</h2><span class="text-sm text-slate-500">Last 6 months</span></div>
        <div v-if="trend.length" class="space-y-3">
          <div v-for="row in trend" :key="row.month" class="grid grid-cols-[90px_1fr_120px] items-center gap-3 text-sm">
            <span class="font-bold">{{ row.month }}</span>
            <div class="h-3 overflow-hidden rounded-full bg-slate-200 dark:bg-slate-800"><div class="h-full rounded-full bg-gold" :style="{ width: barWidth(row.amount, maxTrend) }"></div></div>
            <span class="text-right font-semibold">{{ money(row.amount) }}</span>
          </div>
        </div>
        <p v-else class="text-slate-500">No approved payment trend yet.</p>
      </section>

      <section class="card">
        <div class="mb-5 flex items-center justify-between"><h2 class="text-xl font-black text-navy dark:text-gold">Alumni by Campus</h2><span class="text-sm text-slate-500">Scope-aware</span></div>
        <div v-if="campusCounts.length" class="space-y-4">
          <div v-for="row in campusCounts" :key="row.campus">
            <div class="mb-1 flex justify-between text-sm"><span class="font-bold">{{ niceCampus(row.campus) }}</span><span>{{ row.count }}</span></div>
            <div class="h-3 overflow-hidden rounded-full bg-slate-200 dark:bg-slate-800"><div class="h-full rounded-full bg-navy dark:bg-gold" :style="{ width: barWidth(row.count, maxCampus) }"></div></div>
          </div>
        </div>
        <p v-else class="text-slate-500">No alumni campus data yet.</p>
      </section>
    </div>

    <div class="grid gap-6 lg:grid-cols-2">
      <section class="card overflow-x-auto">
        <h2 class="mb-4 text-xl font-black text-navy dark:text-gold">Recent Alumni</h2>
        <table class="w-full text-sm"><thead><tr class="text-left"><th>Name</th><th>Email</th><th>Campus</th><th>Status</th></tr></thead><tbody><tr v-for="a in alumni" :key="a.id"><td class="py-2">{{ a.displayName }}</td><td>{{ a.email }}</td><td>{{ niceCampus(a.campus) }}</td><td>{{ a.verificationStatus }}</td></tr><tr v-if="!alumni.length"><td colspan="4" class="py-4 text-slate-500">No alumni registered yet.</td></tr></tbody></table>
      </section>
      <section class="card overflow-x-auto">
        <h2 class="mb-4 text-xl font-black text-navy dark:text-gold">Recent Payments</h2>
        <table class="w-full text-sm"><thead><tr class="text-left"><th>Alumni</th><th>Type</th><th>Amount</th><th>Status</th></tr></thead><tbody><tr v-for="p in recentPayments" :key="p.id"><td class="py-2">{{ p.alumni?.displayName || '—' }}</td><td>{{ niceType(p.paymentType) }}</td><td>{{ money(p.amount) }}</td><td>{{ p.status }}</td></tr><tr v-if="!recentPayments.length"><td colspan="4" class="py-4 text-slate-500">No payments yet.</td></tr></tbody></table>
      </section>
    </div>
  </div>
</template>
<script setup>
import { computed, onMounted, ref } from 'vue'; import api from '../api'
const dashboard=ref({}); const alumni=ref([]); const recentPayments=ref([])
const trend=computed(()=>dashboard.value.collectionsTrend || [])
const campusCounts=computed(()=>dashboard.value.campusCounts || [])
const maxTrend=computed(()=>Math.max(1,...trend.value.map(x=>Number(x.amount||0))))
const maxCampus=computed(()=>Math.max(1,...campusCounts.value.map(x=>Number(x.count||0))))
const kpiCards=computed(()=>[
  { label:'Total Alumni', value: dashboard.value.totalAlumni ?? 0, hint:'Registered profiles' },
  { label:'Verified Alumni', value: dashboard.value.verifiedAlumni ?? 0, hint:'Approved profiles' },
  { label:'SACCO Members', value: dashboard.value.saccoMembers ?? 0, hint:'Approved/active' },
  { label:'Pending Payments', value: dashboard.value.pendingPayments ?? 0, hint:'Need admin action' },
  { label:'Admin Files', value: dashboard.value.adminDocuments ?? 0, hint:'Private documents' },
  { label:'Audit Logs', value: dashboard.value.auditLogCount ?? 0, hint:'Tracked actions' },
  { label:'Roles', value: dashboard.value.roleCount ?? 0, hint:'Governance roles' },
  { label:'Campuses', value: dashboard.value.campusCount ?? 0, hint:'Seeta campus records' }
])
function money(v){ return 'UGX ' + Number(v || 0).toLocaleString('en-UG') }
function niceType(v){ return String(v || '—').replaceAll('_',' ').replace(/\b\w/g, c => c.toUpperCase()) }
function niceCampus(v){ return String(v || '—').replace('alevel','A Level').replace(/\b\w/g, c => c.toUpperCase()) }
function barWidth(value, max){ return Math.max(4, Math.round((Number(value||0) / Number(max?.value || max || 1)) * 100)) + '%' }
onMounted(async()=>{ dashboard.value=(await api.get('/admin/dashboard')).data; alumni.value=dashboard.value.recentAlumni || []; recentPayments.value=dashboard.value.recentPayments || [] })
</script>
