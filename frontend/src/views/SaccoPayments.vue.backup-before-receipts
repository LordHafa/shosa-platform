<template>
  <section class="mx-auto max-w-6xl space-y-6">
    <div class="rounded-3xl bg-navy p-6 text-white shadow-xl md:p-8">
      <p class="font-bold text-gold">SACCO payments</p>
      <h1 class="mt-2 text-3xl font-black md:text-4xl">Submit and track payments</h1>
      <p class="mt-3 max-w-3xl leading-7 text-slate-200">
        Select a SACCO payment option. Standard fees are filled automatically and verified by the system.
      </p>
    </div>

    <div v-if="saccoLoading" class="card">Loading SACCO status...</div>

    <div v-else class="grid gap-6 lg:grid-cols-[420px_1fr]">
      <form class="card space-y-4" @submit.prevent="submitPayment">
        <div>
          <h2 class="text-2xl font-black text-navy dark:text-gold">New SACCO payment</h2>
          <p class="mt-2 text-sm leading-6 text-slate-500 dark:text-slate-400">
            Registration fee is paid through SACCO registration. Yearly subscription is fixed at UGX 100,000.
          </p>
        </div>

        <div v-if="!saccoData?.membership" class="rounded-2xl bg-gold/15 p-4 text-sm leading-6 text-navy dark:text-gold">
          You have not started SACCO registration yet. Start SACCO registration before making SACCO payments.
          <router-link to="/sacco/register" class="font-black underline">Start here</router-link>.
        </div>

        <div v-else-if="saccoData.membership.status !== 'active'" class="rounded-2xl bg-gold/15 p-4 text-sm leading-6 text-navy dark:text-gold">
          Your SACCO membership is still <strong>{{ saccoData.membership.status }}</strong>. Wait for admin approval of the registration fee before making other SACCO payments.
        </div>

        <div v-else-if="saccoData.subscription?.isSubscriptionDue" class="rounded-2xl border border-gold/40 bg-gold/10 p-4 text-sm leading-6 text-navy dark:text-gold">
          Your yearly SACCO subscription is due. Pay <strong>UGX 100,000</strong> before making savings payments.
        </div>

        <div v-else-if="saccoData.subscription?.hasPendingYearlySubscription" class="rounded-2xl border border-blue-200 bg-blue-50 p-4 text-sm leading-6 text-blue-800">
          Your yearly subscription payment is pending admin review. Other SACCO payments are paused until approval.
        </div>

        <div>
          <label class="label">Payment Type *</label>
          <select v-model="form.paymentType" class="input" required :disabled="!canSubmitAnyPayment">
            <option v-for="option in availablePaymentOptions" :key="option.value" :value="option.value">
              {{ option.label }}
            </option>
          </select>
        </div>

        <div>
          <label class="label">Amount UGX *</label>

          <input
            v-if="activePaymentOption?.fixed"
            :value="money(form.amount)"
            class="input bg-slate-100 font-black dark:bg-slate-800"
            disabled
          />

          <select v-else v-model="form.amount" class="input" required :disabled="!canSubmitAnyPayment">
            <option value="">Select amount</option>
            <option v-for="amount in activePaymentOption?.amounts || []" :key="amount" :value="String(amount)">
              {{ money(amount) }}
            </option>
          </select>
        </div>

        <div>
          <label class="label">Phone Number *</label>
          <input v-model.trim="form.phone" class="input" inputmode="tel" required placeholder="+256 778120798" :disabled="!canSubmitAnyPayment" />
        </div>

        <div>
          <label class="label">Network *</label>
          <select v-model="form.network" class="input" required :disabled="!canSubmitAnyPayment">
            <option>MTN Mobile Money</option>
            <option>Airtel Money</option>
            <option>Bank Transfer</option>
            <option>Cash / Manual Deposit</option>
            <option>Other</option>
          </select>
        </div>

        <div>
          <label class="label">Transaction Reference</label>
          <input v-model.trim="form.transactionRef" class="input" placeholder="Optional but recommended" :disabled="!canSubmitAnyPayment" />
          <p class="mt-1 text-xs text-slate-500 dark:text-slate-400">
            Helps admins verify faster and prevents duplicate payment confusion.
          </p>
        </div>

        <div>
          <label class="label">Description</label>
          <textarea v-model.trim="form.description" class="input min-h-24" :disabled="!canSubmitAnyPayment"></textarea>
        </div>

        <p v-if="message" class="rounded-lg bg-green-100 p-3 text-green-700">{{ message }}</p>
        <p v-if="error" class="rounded-lg bg-red-100 p-3 text-red-700">{{ error }}</p>

        <button class="btn-primary w-full" :disabled="loading || !canSubmitAnyPayment">
          {{ loading ? 'Submitting...' : 'Submit Payment for Review' }}
        </button>
      </form>

      <div class="card">
        <div class="mb-4 flex flex-wrap items-center justify-between gap-3">
          <div>
            <h2 class="text-2xl font-black text-navy dark:text-gold">My payment history</h2>
            <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">Track approval status and references.</p>
          </div>
          <button class="btn-secondary" @click="loadAll">Refresh</button>
        </div>

        <div class="space-y-3 md:hidden">
          <article
            v-for="p in payments"
            :key="p.id"
            class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-800"
          >
            <div class="flex items-start justify-between gap-3">
              <div>
                <p class="text-xs font-bold uppercase tracking-wide text-gold">{{ p.label || niceType(p.paymentType) }}</p>
                <h3 class="mt-1 text-xl font-black text-navy dark:text-white">{{ money(p.amount) }}</h3>
              </div>
              <span :class="statusBadge(p.status)">{{ niceStatus(p.status) }}</span>
            </div>

            <div class="mt-4 grid gap-2 text-sm text-slate-600 dark:text-slate-300">
              <div class="flex justify-between gap-3"><span class="text-slate-400">Date</span><strong>{{ formatDate(p.createdAt) }}</strong></div>
              <div class="flex justify-between gap-3"><span class="text-slate-400">Network</span><strong class="text-right">{{ p.network || '-' }}</strong></div>
              <div class="flex justify-between gap-3"><span class="text-slate-400">Reference</span><strong class="max-w-[160px] truncate text-right">{{ p.transactionRef || '-' }}</strong></div>
            </div>
          </article>

          <div v-if="!payments.length" class="rounded-2xl bg-cream p-6 text-center text-slate-500 dark:bg-slate-800">
            No payments yet.
          </div>
        </div>

        <div class="hidden overflow-x-auto md:block">
          <table class="w-full min-w-[760px] text-left text-sm">
            <thead>
              <tr class="border-b border-slate-200 dark:border-slate-700">
                <th class="py-3">Date</th>
                <th>Type</th>
                <th>Amount</th>
                <th>Network</th>
                <th>Status</th>
                <th>Reference</th>
              </tr>
            </thead>
            <tbody>
              <tr v-for="p in payments" :key="p.id" class="border-b border-slate-100 dark:border-slate-700">
                <td class="py-3">{{ formatDate(p.createdAt) }}</td>
                <td>{{ p.label || niceType(p.paymentType) }}</td>
                <td>{{ money(p.amount) }}</td>
                <td>{{ p.network || '-' }}</td>
                <td><span :class="statusBadge(p.status)">{{ niceStatus(p.status) }}</span></td>
                <td>{{ p.transactionRef || '-' }}</td>
              </tr>
              <tr v-if="!payments.length">
                <td colspan="6" class="py-8 text-center text-slate-500">No payments yet.</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>
</template>

<script setup>
import { computed, onMounted, reactive, ref, watch } from 'vue'
import api from '../api'

const SACCO_YEARLY_SUBSCRIPTION = 100000

const paymentOptions = [
  {
    value: 'sacco_yearly_subscription',
    label: 'Yearly SACCO Subscription - UGX 100,000',
    fixed: true,
    amount: SACCO_YEARLY_SUBSCRIPTION
  },
  {
    value: 'sacco_savings_monthly',
    label: 'Monthly SACCO Savings',
    fixed: false,
    amounts: [50000, 100000, 200000, 500000]
  },
  {
    value: 'sacco_savings_quarterly',
    label: 'Quarterly SACCO Savings',
    fixed: false,
    amounts: [150000, 300000, 600000, 1500000]
  }
]

const saccoData = ref(null)
const saccoLoading = ref(true)
const payments = ref([])
const loading = ref(false)
const error = ref('')
const message = ref('')

const form = reactive({
  paymentType: 'sacco_yearly_subscription',
  amount: String(SACCO_YEARLY_SUBSCRIPTION),
  phone: '',
  network: 'MTN Mobile Money',
  transactionRef: '',
  description: ''
})

const canSubmitAnyPayment = computed(() => {
  return Boolean(saccoData.value?.membership && saccoData.value.membership.status === 'active')
})

const subscriptionLocksOtherPayments = computed(() => {
  return Boolean(
    saccoData.value?.subscription?.isSubscriptionDue ||
    saccoData.value?.subscription?.hasPendingYearlySubscription
  )
})

const availablePaymentOptions = computed(() => {
  if (subscriptionLocksOtherPayments.value) {
    return paymentOptions.filter(option => option.value === 'sacco_yearly_subscription')
  }

  return paymentOptions
})

const activePaymentOption = computed(() => {
  return paymentOptions.find(option => option.value === form.paymentType) || paymentOptions[0]
})

watch(
  () => form.paymentType,
  () => {
    if (activePaymentOption.value.fixed) {
      form.amount = String(activePaymentOption.value.amount)
    } else {
      form.amount = String(activePaymentOption.value.amounts[0])
    }
  },
  { immediate: true }
)

watch(
  () => availablePaymentOptions.value.map(option => option.value).join(','),
  () => {
    if (!availablePaymentOptions.value.some(option => option.value === form.paymentType)) {
      form.paymentType = availablePaymentOptions.value[0]?.value || 'sacco_yearly_subscription'
    }
  }
)

function money(value) {
  return 'UGX ' + Number(value || 0).toLocaleString('en-UG')
}

function formatDate(value) {
  if (!value) return '-'
  return new Date(value).toLocaleDateString()
}

function niceType(value) {
  return String(value || '-').replaceAll('_', ' ').replace(/\b\w/g, c => c.toUpperCase())
}

function niceStatus(value) {
  return niceType(value)
}

function statusBadge(status) {
  const base = 'inline-flex rounded-full px-3 py-1 text-xs font-black uppercase tracking-wide'
  if (status === 'approved') return `${base} bg-green-100 text-green-700`
  if (status === 'rejected') return `${base} bg-red-100 text-red-700`
  if (status === 'pending_gateway_confirmation') return `${base} bg-blue-100 text-blue-700`
  return `${base} bg-gold/25 text-navy dark:text-gold`
}

async function loadSacco() {
  saccoData.value = (await api.get('/sacco/me')).data
}

async function loadPayments() {
  payments.value = (await api.get('/payments/my')).data
}

async function loadProfilePhone() {
  try {
    const { data } = await api.get('/me')
    if (data?.phone && !form.phone) form.phone = data.phone
  } catch {
    // Profile phone prefill is optional.
  }
}

async function loadAll() {
  saccoLoading.value = true
  error.value = ''

  try {
    await Promise.all([loadSacco(), loadPayments(), loadProfilePhone()])
  } catch (e) {
    error.value = e.response?.data?.error || 'Failed to load payment information'
  } finally {
    saccoLoading.value = false
  }
}

async function submitPayment() {
  loading.value = true
  error.value = ''
  message.value = ''

  try {
    await api.post('/payments/mobilemoney', {
      paymentType: form.paymentType,
      amount: form.amount,
      phone: form.phone,
      network: form.network,
      transactionRef: form.transactionRef,
      description: form.description
    })

    message.value = 'Payment submitted for admin review.'
    form.transactionRef = ''
    form.description = ''

    await loadAll()
  } catch (e) {
    error.value = e.response?.data?.error || 'Payment submission failed'
  } finally {
    loading.value = false
  }
}

onMounted(loadAll)
</script>
