@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
  body { @apply bg-cream text-ink dark:bg-slate-950 dark:text-slate-100; }
  input, select, textarea { @apply text-ink; }
}

@layer components {
  .card { @apply rounded-2xl bg-white p-6 shadow-sm ring-1 ring-slate-200 dark:bg-slate-900 dark:ring-slate-800; }
  .btn-primary { @apply inline-flex items-center justify-center rounded-xl bg-navy px-5 py-2.5 font-semibold text-white hover:opacity-90 disabled:opacity-60; }
  .btn-secondary { @apply inline-flex items-center justify-center rounded-xl bg-gold px-5 py-2.5 font-semibold text-navy hover:opacity-90 disabled:opacity-60; }
  .input { @apply w-full rounded-xl border border-slate-300 bg-white px-4 py-2.5 outline-none focus:border-gold dark:border-slate-700 dark:bg-slate-800 dark:text-white; }
  .label { @apply mb-1 block text-sm font-semibold text-slate-600 dark:text-slate-300; }
}
