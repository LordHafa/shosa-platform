import { createRouter, createWebHistory } from 'vue-router'
import { useAuthStore } from '../stores/auth'

import Home from '../views/Home.vue'
import About from '../views/About.vue'
import Login from '../views/Login.vue'
import Register from '../views/Register.vue'
import Events from '../views/Events.vue'
import Gallery from '../views/Gallery.vue'
import Store from '../views/Store.vue'
import Contact from '../views/Contact.vue'
import Donate from '../views/Donate.vue'
import AlumniDashboard from '../views/AlumniDashboard.vue'
import Profile from '../views/Profile.vue'
import SaccoRegister from '../views/SaccoRegister.vue'
import SaccoDashboard from '../views/SaccoDashboard.vue'
import SaccoPayments from '../views/SaccoPayments.vue'
import AdminDashboard from '../views/AdminDashboard.vue'
import AdminPayments from '../views/AdminPayments.vue'
import AdminGallery from '../views/AdminGallery.vue'
import AdminAuditLogs from '../views/AdminAuditLogs.vue'
import AdminAlumni from '../views/AdminAlumni.vue'
import AdminFiles from '../views/AdminFiles.vue'
import AdminContacts from '../views/AdminContacts.vue'
import AdminUsers from '../views/AdminUsers.vue'

const routes = [
  { path: '/', component: Home },
  { path: '/about', component: About },
  { path: '/events', component: Events },
  { path: '/gallery', component: Gallery },
  { path: '/store', component: Store },
  { path: '/contact', component: Contact },
  { path: '/donate', component: Donate },
  { path: '/login', component: Login },
  { path: '/register', component: Register },
  { path: '/alumni/dashboard', component: AlumniDashboard, meta: { requiresAuth: true, type: 'alumni' } },
  { path: '/profile', component: Profile, meta: { requiresAuth: true, type: 'alumni' } },
  { path: '/sacco/register', component: SaccoRegister, meta: { requiresAuth: true, type: 'alumni' } },
  { path: '/sacco/dashboard', component: SaccoDashboard, meta: { requiresAuth: true, type: 'alumni' } },
  { path: '/sacco/payments', component: SaccoPayments, meta: { requiresAuth: true, type: 'alumni' } },
  { path: '/admin', component: AdminDashboard, meta: { requiresAuth: true, type: 'admin' } },
  { path: '/admin/alumni', component: AdminAlumni, meta: { requiresAuth: true, type: 'admin' } },
  { path: '/admin/payments', component: AdminPayments, meta: { requiresAuth: true, type: 'admin' } },
  { path: '/admin/gallery', component: AdminGallery, meta: { requiresAuth: true, type: 'admin' } },
  { path: '/admin/files', component: AdminFiles, meta: { requiresAuth: true, type: 'admin' } },
  { path: '/admin/contacts', component: AdminContacts, meta: { requiresAuth: true, type: 'admin' } },
  { path: '/admin/audit-logs', component: AdminAuditLogs, meta: { requiresAuth: true, type: 'admin' } },
  { path: '/admin/users', component: AdminUsers, meta: { requiresAuth: true, type: 'admin' } }
]

const router = createRouter({ history: createWebHistory(), routes })

router.beforeEach((to) => {
  const auth = useAuthStore()
  if (to.meta.requiresAuth && !auth.isLoggedIn) return '/login'
  if (to.meta.type === 'admin' && !auth.isAdmin) return '/login'
  if (to.meta.type === 'alumni' && !auth.isAlumni) return '/login'
})

export default router
